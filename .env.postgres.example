# PostgreSQL connection settings for local testing
# Copy this file to .env.postgres and adjust values as needed
# Then either source it before running tests or use run_tests.ps1

# Connection string (recommended - sets all in one line)
# POSTGRES_CONNECTION_STRING=postgresql://trader:trader_pwd@localhost:5432/trading

# Or individual settings (all three required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pwd
