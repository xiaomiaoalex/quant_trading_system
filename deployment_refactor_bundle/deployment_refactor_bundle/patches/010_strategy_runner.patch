+    def _build_runtime_init_config(
+        self,
+        *,
+        strategy_id: str,
+        deployment_id: str,
+        config: Optional[Dict[str, Any]],
+        symbols: Optional[List[str]],
+        account_id: str,
+        venue: str,
+        mode: str,
+        module_path: Optional[str],
+    ) -> Dict[str, Any]:
+        merged = dict(config or {})
+        merged.setdefault("symbols", list(symbols or merged.get("symbols") or []))
+        merged["strategy_id"] = strategy_id
+        merged["deployment_id"] = deployment_id
+        merged["account_id"] = account_id
+        merged["venue"] = venue
+        merged["mode"] = mode
+        if module_path is not None:
+            merged.setdefault("module_path", module_path)
+        return merged
+
+    def _instantiate_plugin(
+        self,
+        factory_owner: Any,
+        *,
+        strategy_id: str,
+        deployment_id: str,
+        config: Optional[Dict[str, Any]] = None,
+        symbols: Optional[List[str]] = None,
+    ) -> StrategyPlugin:
+        factory = None
+        for attr in ("create_plugin", "build_plugin", "get_plugin"):
+            candidate = getattr(factory_owner, attr, None)
+            if callable(candidate):
+                factory = candidate
+                break
+
+        if factory is None:
+            raise ValueError("策略模块缺少 create_plugin()/get_plugin() 工厂函数")
+
+        kwargs = {
+            "strategy_id": strategy_id,
+            "deployment_id": deployment_id,
+            "config": dict(config or {}),
+            "symbols": list(symbols or []),
+        }
+
+        try:
+            signature = inspect.signature(factory)
+            accepted = {
+                name: value
+                for name, value in kwargs.items()
+                if name in signature.parameters
+            }
+            plugin = factory(**accepted)
+        except (TypeError, ValueError):
+            plugin = factory()
+
+        if any(plugin is existing for existing in self._plugins.values()):
+            raise ValueError(
+                "策略工厂返回了共享单例对象。请删除模块级 `_plugin_instance`，并改为 `create_plugin()` 每次返回新实例。"
+            )
+
+        is_valid, error_msg = validate_strategy_plugin(plugin)
+        if not is_valid:
+            raise TypeError(f"策略插件未实现 StrategyPlugin 协议: {error_msg}")
+
+        if hasattr(plugin, "strategy_id"):
+            plugin.strategy_id = strategy_id
+        if hasattr(plugin, "deployment_id"):
+            plugin.deployment_id = deployment_id
+        if hasattr(plugin, "symbols"):
+            plugin.symbols = list(symbols or [])
+
+        return plugin
 
