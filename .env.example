# Binance Demo API Configuration
# Copy this file to .env and fill in your API credentials.
# IMPORTANT: Never commit .env to version control.

# Binance Spot Demo execution environment.
# Current execution adapter supports demo/testnet; this project defaults to demo.
BINANCE_ENV=demo
BINANCE_API_KEY=your_demo_api_key_here
BINANCE_SECRET_KEY=your_demo_secret_key_here
BINANCE_RECV_WINDOW=5000

# Keep automated order placement disabled for read-only risk rehearsals.
LIVE_TRADING_ENABLED=false

# Optional: System order namespace prefix for automatic order ownership identification.
# Orders with client_order_id starting with this prefix are considered OWNED by this system.
# Default: QTS1_
SYSTEM_ORDER_NAMESPACE_PREFIX=QTS1_

# Optional: only reconcile exchange orders whose client_order_id starts with these prefixes.
# Comma-separated, e.g. fire_test_,mybot_
# This is a legacy compatibility option. New deployments should use SYSTEM_ORDER_NAMESPACE_PREFIX.
RECONCILER_EXCHANGE_CLIENT_ORDER_PREFIXES=

# Proxy Configuration (if behind VPN/proxy)
# Format: http://proxy_host:proxy_port
# Example: http://127.0.0.1:4780
BINANCE_PROXY_URL=

# Crypto Risk read-only USD-M source.
# The execution environment above remains Binance Spot Demo; this URL only controls
# the read-only source used by /v1/risk/crypto/probe and pre-trade risk snapshots.
CRYPTO_RISK_ENABLED=false
CRYPTO_RISK_FUTURES_BASE_URL=https://demo-api.binance.com/fapi
CRYPTO_RISK_BASE_SYMBOLS=BTCUSDT,ETHUSDT
CRYPTO_RISK_TOTAL_NOTIONAL_CAP=10000
CRYPTO_RISK_SYMBOL_NOTIONAL_CAPS=BTCUSDT=7000,ETHUSDT=3000
CRYPTO_RISK_SYMBOL_CLUSTERS=BTCUSDT=BTC_BETA,ETHUSDT=ETH_BETA
CRYPTO_RISK_CLUSTER_NOTIONAL_CAPS=BTC_BETA=8000,ETH_BETA=4000
CRYPTO_RISK_MAX_MARGIN_RATIO=0.60
CRYPTO_RISK_MIN_LIQUIDATION_BUFFER_RATIO=0.08
CRYPTO_RISK_TIMEOUT_SECONDS=10
CRYPTO_RISK_PROXY_URL=
CRYPTO_RISK_MAX_RETRIES=2

# Legacy explicit endpoint variables. Prefer BINANCE_ENV unless a script explicitly
# asks for these values.
BINANCE_REST_URL=https://demo-api.binance.com/api
BINANCE_WS_URL=wss://demo-stream.binance.com/ws
